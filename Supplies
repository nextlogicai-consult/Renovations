<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>311 Candle Place SW — Landscape Estimate</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --stone: #c4b5a0;
    --moss: #5a6e4a;
    --soil: #3d2e1e;
    --pebble: #8c7b6b;
    --cream: #f5f0ea;
    --bark: #2a1f14;
    --rock: #6b6158;
    --sky: #dde8d0;
    --accent: #8fa870;
  }

  body {
    background: var(--bark);
    font-family: 'Instrument Sans', sans-serif;
    padding: 40px 20px;
    min-height: 100vh;
  }

  .page {
    max-width: 960px;
    margin: 0 auto;
    background: var(--cream);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 20px 80px rgba(0,0,0,0.5);
  }

  /* HEADER */
  .header {
    background: var(--soil);
    padding: 36px 48px 32px;
    position: relative;
    overflow: hidden;
  }

  .header::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 40px,
      rgba(255,255,255,0.015) 40px,
      rgba(255,255,255,0.015) 80px
    );
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
  }

  .address-block h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 28px;
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 6px;
  }

  .address-block h2 {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: 16px;
    color: var(--stone);
    font-weight: 400;
    letter-spacing: 0.5px;
  }

  .total-badge {
    background: var(--moss);
    border-radius: 3px;
    padding: 16px 24px;
    text-align: right;
    flex-shrink: 0;
  }

  .total-badge .label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--sky);
    margin-bottom: 4px;
  }

  .total-badge .amount {
    font-family: 'DM Mono', monospace;
    font-size: 26px;
    font-weight: 500;
    color: #fff;
  }

  .header-stats {
    display: flex;
    gap: 32px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .stat .s-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--pebble);
  }

  .stat .s-value {
    font-family: 'DM Mono', monospace;
    font-size: 15px;
    color: var(--stone);
  }

  .suppliers-note {
    margin-top: 10px;
    font-size: 11px;
    color: var(--rock);
    font-style: italic;
  }

  /* BODY */
  .body {
    padding: 0 48px 48px;
  }

  /* PHASE */
  .phase-block {
    margin-top: 32px;
  }

  .phase-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--soil);
  }

  .phase-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--moss);
    flex-shrink: 0;
  }

  .phase-title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--soil);
  }

  /* TABLE */
  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead th {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--rock);
    font-weight: 600;
    padding: 6px 10px;
    text-align: left;
    background: #ede7df;
  }

  thead th.right { text-align: right; }

  tbody tr {
    border-bottom: 1px solid #e8e0d5;
  }

  tbody tr:last-child { border-bottom: none; }

  tbody tr:hover { background: rgba(90,110,74,0.04); }

  td {
    padding: 9px 10px;
    font-size: 12px;
    color: var(--soil);
    vertical-align: top;
  }

  td.product {
    font-weight: 500;
    color: var(--bark);
    max-width: 200px;
  }

  td.purpose {
    font-size: 11px;
    color: var(--pebble);
    max-width: 220px;
    line-height: 1.4;
  }

  td.note {
    font-size: 10px;
    color: var(--rock);
    max-width: 200px;
    line-height: 1.4;
    font-style: italic;
  }

  td.num {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    text-align: right;
    white-space: nowrap;
  }

  td.total-cell {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    text-align: right;
    font-weight: 500;
    color: var(--moss);
    white-space: nowrap;
  }

  td.zero { color: #bbb; }

  /* PHASE SUBTOTAL */
  .phase-sub {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 12px;
    padding: 6px 10px;
    background: #ede7df;
    border-radius: 0 0 2px 2px;
    margin-bottom: 2px;
  }

  .phase-sub span {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--pebble);
  }

  .phase-sub strong {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: var(--soil);
  }

  /* FOOTER TOTAL */
  .grand-total {
    margin-top: 36px;
    display: flex;
    justify-content: flex-end;
  }

  .gt-box {
    background: var(--soil);
    padding: 20px 32px;
    border-radius: 3px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .gt-box .gt-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--pebble);
  }

  .gt-box .gt-amount {
    font-family: 'DM Mono', monospace;
    font-size: 30px;
    font-weight: 500;
    color: var(--cream);
  }

  .legend {
    margin-top: 24px;
    padding: 14px 18px;
    background: var(--sky);
    border-radius: 3px;
    font-size: 11px;
    color: var(--moss);
    line-height: 1.8;
  }

  .legend strong { color: var(--bark); }

  .disclaimer {
    margin-top: 10px;
    font-size: 10px;
    color: var(--rock);
    font-style: italic;
  }
</style>
</head>
<body>
<div class="page">

  <!-- HEADER -->
  <div class="header">
